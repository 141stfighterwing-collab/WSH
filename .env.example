# WSH - Weavenote Self Hosted Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL="postgresql://wsh:wsh_secure_password@localhost:5432/wsh_db?schema=public"

# For Docker deployment, use:
# DATABASE_URL="postgresql://wsh:wsh_secure_password@postgres:5432/wsh_db?schema=public"

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# IMPORTANT: Change this to a strong random string in production!
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NEXT_PUBLIC_APP_NAME="WSH - Weavenote Self Hosted"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# DEFAULT ADMIN USER (Created on first run)
# =============================================================================
ADMIN_EMAIL="admin@wsh.local"
ADMIN_PASSWORD="admin123"
ADMIN_USERNAME="Admin"

# =============================================================================
# POWERSHELL EXECUTOR SETTINGS
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# Log format: text or json
LOG_FORMAT="text"

# Maximum retry attempts for failed operations
MAX_RETRIES="3"

# Delay between retries in seconds
RETRY_DELAY="5"

# Default script timeout in seconds
DEFAULT_TIMEOUT="3600"

# Enable PowerShell strict mode
STRICT_MODE="true"

# Error action preference: Stop, Continue, SilentlyContinue
ERROR_ACTION="Stop"

# Health check settings
HEALTH_CHECK_ENABLED="true"
HEALTH_CHECK_PORT="8080"

# Timezone
TZ="UTC"

# =============================================================================
# OPTIONAL: EXTERNAL SERVICES
# =============================================================================
# Uncomment and configure if using external services
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-password"
