# ── WSH Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and edit values for your deployment.
#   cp .env.example .env
#
# All variables have sensible defaults — you only need to change
# POSTGRES_PASSWORD, JWT_SECRET, and ADMIN_DEFAULT_PASSWORD for a secure setup.

# ── Application ────────────────────────────────────────────────────────────
PORT=8883
HOSTNAME=0.0.0.0
APP_NAME=WSH

# ── Ports ─────────────────────────────────────────────────────────────────
WSH_PORT=8883
DB_VIEWER_PORT=5682
PGADMIN_PORT=5050

# ── PostgreSQL Database ────────────────────────────────────────────────────
# WARNING: Change POSTGRES_PASSWORD before deploying to any network-accessible environment.
# The default password below is for local development only.
POSTGRES_USER=wsh
POSTGRES_PASSWORD=wsh-secret-pw
POSTGRES_DB=weavenote
DATABASE_URL=postgresql://wsh:wsh-secret-pw@postgres:5432/weavenote

# ── Authentication ─────────────────────────────────────────────────────────
# SECURITY WARNING: You MUST change these values before any production deployment.
# JWT_SECRET: Used to sign authentication tokens. Use a random 32+ character string.
#   Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADMIN_DEFAULT_PASSWORD: Must be at least 8 characters with mixed complexity.
JWT_SECRET=change-me-in-production
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=admin123

# ── pgAdmin (optional — only when using --profile admin) ───────────────────
# WARNING: Change PGADMIN_PASSWORD before exposing pgAdmin to any network.
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin123

# ── AI Synthesis ───────────────────────────────────────────────────────────
# Set AI_PROVIDER to 'claude', 'openai', or 'gemini' (auto-detected from API keys if not set)
# At least one API key must be configured for AI features to work.
AI_PROVIDER=gemini
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_SYNTHESIS_MODEL=
AI_SYNTHESIS_TEMPERATURE=0.7
AI_SYNTHESIS_MAX_TOKENS=4096
AI_DAILY_LIMIT=800
# Optional: Custom OpenAI-compatible base URL (e.g., for Azure OpenAI or local LLMs)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Storage & Backups ──────────────────────────────────────────────────────
STORAGE_TYPE=local
BACKUP_INTERVAL=24h

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Upload ─────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=10mb
