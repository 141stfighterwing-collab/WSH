# ── WSH Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and edit values for your deployment.
#   cp .env.example .env
#
# All variables have sensible defaults — you only need to change
# POSTGRES_PASSWORD, JWT_SECRET, and ADMIN_DEFAULT_PASSWORD for a secure setup.

# ── Application ────────────────────────────────────────────────────────────
PORT=3000
HOSTNAME=0.0.0.0
APP_NAME=WSH

# ── Ports ─────────────────────────────────────────────────────────────────
WSH_PORT=3000
DB_VIEWER_PORT=5682
PGADMIN_PORT=5050

# ── PostgreSQL Database ────────────────────────────────────────────────────
POSTGRES_USER=wsh
POSTGRES_PASSWORD=wsh-secret-pw
POSTGRES_DB=weavenote
DATABASE_URL=postgresql://wsh:wsh-secret-pw@postgres:5432/weavenote

# ── Authentication ─────────────────────────────────────────────────────────
# IMPORTANT: Change these in production!
JWT_SECRET=change-me-in-production
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_EMAIL=admin@wsh.local
ADMIN_DEFAULT_PASSWORD=admin123

# ── pgAdmin (optional — only when using --profile admin) ───────────────────
PGADMIN_EMAIL=admin@wsh.local
PGADMIN_PASSWORD=admin123

# ── AI Synthesis (z-ai-web-dev-sdk) ────────────────────────────────────────
AI_SYNTHESIS_MODEL=glm-4-flash
AI_SYNTHESIS_TEMPERATURE=0.7
AI_SYNTHESIS_MAX_TOKENS=4096
AI_DAILY_LIMIT=800

# ── Storage & Backups ──────────────────────────────────────────────────────
STORAGE_TYPE=local
BACKUP_INTERVAL=24h

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Upload ─────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=10mb
