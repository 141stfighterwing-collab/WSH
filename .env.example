# PostgreSQL Database (REQUIRED)
DATABASE_URL="postgresql://wsh:wsh_secure_password@localhost:5432/wsh_db?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Application
NEXT_PUBLIC_APP_NAME="WSH - Weavenote Self Hosted"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin Default Credentials (used on first setup)
ADMIN_EMAIL="admin@wsh.local"
ADMIN_PASSWORD="admin123"
ADMIN_USERNAME="Admin"

# AI Configuration (Optional - for AI features)
# GEMINI_API_KEY="your-gemini-api-key"
