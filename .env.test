# ── WSH Test Environment Variables ──────────────────────────────────────────
# This file contains EXAMPLE values for testing and validation.
#
# DO NOT use this file directly as your .env — it contains non-secret test values.
# Instead, copy it as a reference:
#   cp .env.test .env.test-reference
#
# For your actual deployment, use:
#   cp .env.example .env
#   # Then edit .env with your real values

# ── Application ────────────────────────────────────────────────────────────
PORT=8883
HOSTNAME=0.0.0.0
APP_NAME=WSH

# ── Ports ─────────────────────────────────────────────────────────────────
WSH_PORT=8883
DB_VIEWER_PORT=5682
PGADMIN_PORT=5050

# ── PostgreSQL Database (test values) ──────────────────────────────────────
# These are the default test/dev values. NEVER use these in production.
POSTGRES_USER=wsh
POSTGRES_PASSWORD=wsh-test-password-change-me
POSTGRES_DB=weavenote_test
DATABASE_URL=postgresql://wsh:wsh-test-password-change-me@postgres:5432/weavenote_test

# ── Authentication (test values) ──────────────────────────────────────────
# SECURITY WARNING: These are TEST credentials only.
# Generate a real JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=test-jwt-secret-do-not-use-in-production-32chars
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_EMAIL=admin@test.local
ADMIN_DEFAULT_PASSWORD=admin123

# ── pgAdmin (test values) ─────────────────────────────────────────────────
PGADMIN_EMAIL=admin@test.local
PGADMIN_PASSWORD=test-admin-password

# ── AI Synthesis (test values — NOT real keys) ────────────────────────────
# These are example/test keys to verify the ENV persistence system works.
# They will NOT authenticate against any real AI provider.
#
# Test with the test-env.sh script:
#   ADMIN_USER=admin ADMIN_PASS=admin123 TEST_KEY=sk-test-12345 ./test-env.sh
#
# Real key format examples (replace with your actual keys):
AI_PROVIDER=openai
# Anthropic Claude key format: sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX
ANTHROPIC_API_KEY=sk-ant-test-key-for-validation-only
# OpenAI key format: sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_API_KEY=sk-test-key-for-validation-only
# Google Gemini key format: AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_API_KEY=AIzaSy-test-key-for-validation-only

# Model settings
AI_SYNTHESIS_MODEL=gpt-4o-mini
AI_SYNTHESIS_TEMPERATURE=0.7
AI_SYNTHESIS_MAX_TOKENS=4096
AI_DAILY_LIMIT=800

# Custom OpenAI-compatible base URL (for Azure OpenAI, Ollama, LM Studio, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=http://localhost:11434/v1          # Ollama local
# OPENAI_BASE_URL=http://localhost:1234/v1           # LM Studio local

# ── Storage & Backups ──────────────────────────────────────────────────────
STORAGE_TYPE=local
BACKUP_INTERVAL=24h

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Upload ─────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=10mb

# ── Test Script Configuration ──────────────────────────────────────────────
# These variables are used by test-env.sh and test-env.ps1
# Override on command line: ADMIN_USER=myuser ADMIN_PASS=mypass ./test-env.sh
# ADMIN_USER=admin
# ADMIN_PASS=admin123
# TEST_KEY=sk-test-key-for-validation-only
# WSH_PORT=8883
