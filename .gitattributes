# .gitattributes — enforce line endings (BUG-011 fix)
# Prevent CRLF contamination of shell scripts inside Docker containers

* text=auto eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.prisma text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
