# ==============================================================================
# WSH (Weavenote Self Hosted) - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and customize for your deployment
# Command: copy .env.example .env
# ==============================================================================

# ==============================================================================
# PostgreSQL Database Configuration
# ==============================================================================
# REQUIRED: Configure these for your database setup
# SECURITY WARNING: Change the password for production deployments!

# Database connection URL (internal Docker network)
DATABASE_URL="postgresql://wsh:YOUR_SECURE_PASSWORD_HERE@postgres:5432/wsh_db?schema=public"

# PostgreSQL credentials
POSTGRES_USER="wsh"
POSTGRES_PASSWORD="YOUR_SECURE_PASSWORD_HERE"
POSTGRES_DB="wsh_db"

# Database port (default: 5432)
# POSTGRES_PORT=5432

# ==============================================================================
# JWT Configuration
# ==============================================================================
# REQUIRED: Configure for authentication security
# SECURITY WARNING: Use a strong, unique secret (minimum 32 characters)

# JWT signing secret - generate a secure random string
# Example PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes([System.Guid]::NewGuid().ToString() + [System.Guid]::NewGuid().ToString()))
JWT_SECRET="YOUR_JWT_SECRET_HERE_MIN_32_CHARS"

# Token expiration time
JWT_EXPIRES_IN="7d"

# ==============================================================================
# Application Configuration
# ==============================================================================

# Application display name
NEXT_PUBLIC_APP_NAME="WSH - Weavenote Self Hosted"

# Application URL (update for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Application port (default: 3000)
# APP_PORT=3000

# ==============================================================================
# Admin Default Credentials
# ==============================================================================
# SECURITY WARNING: Change these immediately after first login!
# These credentials are used to create the initial admin user

ADMIN_EMAIL="admin@wsh.local"
ADMIN_PASSWORD="admin123"
ADMIN_USERNAME="Admin"

# ==============================================================================
# pgAdmin Configuration (Optional)
# ==============================================================================
# Only used when starting with --profile admin

# pgAdmin login credentials
PGADMIN_EMAIL="admin@wsh.local"
PGADMIN_PASSWORD="admin"

# pgAdmin port (default: 5050)
# PGADMIN_PORT=5050

# ==============================================================================
# AI Configuration (Optional)
# ==============================================================================
# Uncomment and configure to enable AI features

# GEMINI_API_KEY="your-gemini-api-key"

# ==============================================================================
# Production Deployment Checklist
# ==============================================================================
# Before deploying to production, ensure you have:
#
# 1. [ ] Changed POSTGRES_PASSWORD to a strong, unique password
# 2. [ ] Generated a secure JWT_SECRET (32+ characters)
# 3. [ ] Updated NEXT_PUBLIC_APP_URL to your production URL
# 4. [ ] Changed ADMIN_EMAIL and ADMIN_PASSWORD
# 5. [ ] Configured HTTPS (use reverse proxy like nginx/traefik)
# 6. [ ] Set up regular database backups
# 7. [ ] Configured log rotation
# 8. [ ] Review firewall rules for exposed ports
#
# ==============================================================================

# ==============================================================================
# Example Production Configuration
# ==============================================================================
# Below is an example of how your production .env might look:
#
# DATABASE_URL="postgresql://wsh_prod:Xk9#mP2$vL7nQ4wR@postgres:5432/wsh_db?schema=public"
# POSTGRES_USER="wsh_prod"
# POSTGRES_PASSWORD="Xk9#mP2$vL7nQ4wR"
# POSTGRES_DB="wsh_db"
# JWT_SECRET="aB3dE7fG9hJ2kL5mN8pQ1rS4tU6vW0xY"
# JWT_EXPIRES_IN="24h"
# NEXT_PUBLIC_APP_NAME="WSH Production"
# NEXT_PUBLIC_APP_URL="https://wsh.yourdomain.com"
# ADMIN_EMAIL="admin@yourdomain.com"
# ADMIN_PASSWORD="ChangeMeImmediately2024!"
# ADMIN_USERNAME="SystemAdmin"
#
# ==============================================================================
